# Notion API
# Notion Integration의 Internal Integration Token (서버사이드 전용, NEXT_PUBLIC_ 접두사 사용 금지)
NOTION_API_KEY=your_notion_integration_token_here
# 견적서 데이터베이스 ID (Notion DB URL에서 추출한 32자리 ID)
NOTION_DATABASE_ID=your_notion_database_id_here
# 견적 항목(Items) 데이터베이스 ID — Items DB 우측 상단 "..." → "Add connections"에서 동일 Integration 연결 필요
NOTION_ITEMS_DATABASE_ID=your_notion_items_database_id_here

# 앱 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 관리자 인증 (서버사이드 전용)
# bcryptjs 해시된 비밀번호 — 생성: node -e "require('bcryptjs').hash('your_password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=
# JWT 서명 비밀키 (최소 32자 랜덤 문자열) — 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
