# 데이터베이스
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoce

# 인증
JWT_SECRET=your_jwt_secret_here
# AES-256-GCM 암호화 키 — 32바이트(64자 hex) 문자열
ENCRYPTION_KEY=your_32_byte_encryption_key_here

# Notion API (사용자별 연동)
# NOTION_API_KEY는 사용자가 Notion 연동 페이지에서 직접 입력 후 DB에 암호화 저장
# 서버사이드 암호화에만 사용되는 키 → ENCRYPTION_KEY로 통합

# 앱 설정
NEXT_PUBLIC_APP_URL=http://localhost:3000
